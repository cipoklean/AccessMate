# ── AI provider ───────────────────────────────────────────────────────
# Pick a primary provider and set its API key.
# If a fallback key is also set, AccessMate auto-fails over to it on rate
# limits, auth errors, or server outages. Text-only fallbacks (Groq) are
# skipped for vision/alt-text requests.

# Optional — which provider to use as primary (gemini | openai | groq). Defaults to gemini.
# LLM_PROVIDER=gemini

# Optional — override the default model for the active provider.
#   gemini: gemini-2.5-flash
#   openai:  gpt-4o-mini
#   groq:    llama-3.3-70b-versatile
# LLM_MODEL=gemini-2.5-flash

# Required for gemini (default primary provider) — Google AI Studio key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ── Fallback provider (optional) ──────────────────────────────────────
# Set this to auto-failover when Gemini is rate-limited or down.
# Groq has a free tier and works well for text tasks (simplify, Q&A).
# It cannot process images — alt-text requests skip it.
GROQ_API_KEY=

# ── Slack tokens (required when running without the Slack CLI) ────────
SLACK_BOT_TOKEN=xoxb-YOUR-BOT-TOKEN
SLACK_APP_TOKEN=xapp-YOUR-APP-TOKEN

# ── Optional ──────────────────────────────────────────────────────────
# Override the default log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Override the default HTTP port (Render sets this automatically)
PORT=3000
