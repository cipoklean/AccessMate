{
  "display_information": {
    "name": "AccessMate",
    "description": "Slack, for everyone. Accessibility companion: alt text, plain-language summaries, screen-reader-friendly digests.",
    "background_color": "#6B46C1"
  },
  "features": {
    "assistant_view": {
      "assistant_description": "Hi, I am an agent built using Bolt for JavaScript. I am here to help you out!",
      "suggested_prompts": []
    },
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "AccessMate",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/accessmate",

        "description": "AccessMate accessibility commands",
        "usage_hint": "ping | alt | simplify | digest"
      }
    ],
    "shortcuts": [
      {
        "name": "Generate alt text",
        "type": "message",
        "callback_id": "generate_alt_text",
        "description": "Generate accessibility-friendly alt text for an image in this message"

      },
      {
        "name": "Simplify thread",
        "type": "message",
        "callback_id": "simplify_thread",
        "description": "Plain-language summary of this thread for accessibility"
      }
    ]
  },
  "oauth_config": {
    "redirect_urls": ["https://ngrok-free.app/slack/oauth_redirect"],
    "scopes": {
      "user": [
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "mpim:history",
        "users:read",
        "search:read.public",
        "search:read.private",
        "search:read.mpim",
        "search:read.im",
        "search:read.files",
        "search:read.users",
        "chat:write",
        "canvases:read",
        "canvases:write",
        "users:read.email"
      ],
      "bot": [
        "app_mentions:read",
        "channels:history",
        "chat:write",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "reactions:write",
        "reactions:read",
        "users:read",
        "assistant:write",
        "commands",
        "files:read",
        "channels:read",
        "groups:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://ngrok-free.app/slack/events",
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "assistant_thread_started",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://ngrok-free.app/slack/events"
    },
    "is_mcp_enabled": true,
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
